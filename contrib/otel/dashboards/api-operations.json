        "rowsFrame": { "layout": "auto" },
        "tooltip": { "mode": "single", "showColorScale": false, "yHistogram": false },
        "yAxis": { "axisPlacement": "left", "reverse": false, "unit": "s" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "editorMode": "code",
          "expr": "sum by (le) (increase(openstack_tester_operation_duration_seconds_bucket{operation=~\"$operation\", cloud=~\"$cloud\", scenario=~\"$scenario\", service=~\"$service\"}[$__rate_interval]))",
          "format": "heatmap",
          "legendFormat": "{{le}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Latency distribution",
      "type": "heatmap"
    },
    {
