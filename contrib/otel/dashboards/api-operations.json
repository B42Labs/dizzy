        "cellHeight": "sm",
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "editorMode": "code",
          "expr": "sum by (kind, outcome) (increase(openstack_tester_operation_duration_seconds_count{operation=~\"$operation\", cloud=~\"$cloud\", scenario=~\"$scenario\", service=~\"$service\"}[$__range]))",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "range": false,
          "refId": "A"
        }
      ],
      "title": "Ops by kind and outcome over the dashboard range",
      "transformations": [
        {
          "id": "groupingToMatrix",
          "options": { "columnField": "outcome", "emptyValue": "zero", "rowField": "kind", "valueField": "Value" }
        }
      ],
      "type": "table"
    },
    {
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "description": "Failed API calls per second by error kind (quota, http_<status>, timeout, canceled, other), per resource kind and operation, from the dedicated errors counter — the report's Errors table over time. Empty on a healthy run: only failed operations create these series.",
