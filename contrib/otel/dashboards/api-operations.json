          "editorMode": "code",
          "expr": "sum by (kind) (rate(openstack_tester_operation_duration_seconds_count{outcome=\"success\", operation=~\"$operation\", cloud=~\"$cloud\", scenario=~\"$scenario\", service=~\"$service\"}[$__rate_interval]))",
          "legendFormat": "{{kind}}",
