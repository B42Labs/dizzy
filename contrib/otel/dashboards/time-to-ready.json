        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Resource readiness: how long status-bearing resources take to reach their expected status, per kind. Percentiles are estimated from histogram buckets (labelled \"(est.)\"); the distribution shape is shown as a heatmap over the buckets because true per-resource min/max are not in the OTLP data. Readiness outcome is success / timeout. Sampling caveat: with the default continuous monitor (MONITOR_INTERVAL=0) metrics flow steadily; on a paced run they move only while an iteration runs. Panels use $__rate_interval with a 1m minimum interval.",
  "editable": true,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "description": "Time from create returning to a resource reaching its expected status, per kind, estimated from histogram buckets.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" }
          },
          "mappings": [],
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "interval": "1m",
      "options": {
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "editorMode": "code",
          "expr": "histogram_quantile(0.5, sum by (kind, le) (rate(openstack_tester_resource_time_to_ready_seconds_bucket{cloud=~\"$cloud\", scenario=~\"$scenario\"}[$__rate_interval])))",
          "legendFormat": "{{kind}} p50",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum by (kind, le) (rate(openstack_tester_resource_time_to_ready_seconds_bucket{cloud=~\"$cloud\", scenario=~\"$scenario\"}[$__rate_interval])))",
          "legendFormat": "{{kind}} p95 (est.)",
          "range": true,
          "refId": "B"
        }
      ],
      "title": "Time-to-ready p50 / p95 (est.) by kind",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "description": "Fraction of readiness checks per kind that reached the expected status before the deadline (outcome success vs. timeout), over the dashboard time range.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "max": 1,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.9 },
              { "color": "green", "value": 0.99 }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 2,
      "options": {
        "displayMode": "gradient",
        "maxVizHeight": 300,
        "minVizHeight": 16,
        "minVizWidth": 8,
        "namePlacement": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showUnfilled": true,
        "valueMode": "color"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "editorMode": "code",
          "expr": "sum by (kind) (increase(openstack_tester_resource_time_to_ready_seconds_count{outcome=\"success\", cloud=~\"$cloud\", scenario=~\"$scenario\"}[$__range])) / sum by (kind) (increase(openstack_tester_resource_time_to_ready_seconds_count{cloud=~\"$cloud\", scenario=~\"$scenario\"}[$__range]))",
          "instant": true,
          "legendFormat": "{{kind}}",
          "range": false,
          "refId": "A"
        }
      ],
      "title": "Readiness success ratio by kind",
      "type": "bargauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "description": "Distribution of time-to-ready across the histogram buckets (0.05 s to 300 s). Shows the shape the percentile panel summarises.",
      "fieldConfig": {
        "defaults": {
          "custom": { "hideFrom": { "legend": false, "tooltip": false, "viz": false }, "scaleDistribution": { "type": "linear" } }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 3,
      "interval": "1m",
      "options": {
        "calculate": false,
        "cellGap": 1,
        "color": {
          "exponent": 0.5,
          "fill": "dark-orange",
          "mode": "scheme",
          "reverse": false,
          "scale": "exponential",
          "scheme": "Spectral",
          "steps": 64
        },
        "exemplars": { "color": "rgba(255,0,255,0.7)" },
        "filterValues": { "le": 1e-9 },
        "legend": { "show": true },
        "rowsFrame": { "layout": "auto" },
        "tooltip": { "mode": "single", "showColorScale": false, "yHistogram": false },
        "yAxis": { "axisPlacement": "left", "reverse": false, "unit": "s" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "editorMode": "code",
          "expr": "sum by (le) (increase(openstack_tester_resource_time_to_ready_seconds_bucket{cloud=~\"$cloud\", scenario=~\"$scenario\"}[$__rate_interval]))",
          "format": "heatmap",
          "legendFormat": "{{le}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Time-to-ready distribution",
      "type": "heatmap"
    }
  ],
  "refresh": "1m",
